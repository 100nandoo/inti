{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "web-src/src/**/*.js",
    "web-src/src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "web/**",
    "web/js/**/*.test.js"
  ]
}
