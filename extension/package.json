{
  "name": "inti",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm run dev:firefox",
    "dev:chrome": "wxt -b chrome --mv3",
    "dev:firefox": "node scripts/clean-firefox-dist.mjs && wxt -b firefox",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "wxt build -b chrome --mv3",
    "build:firefox": "node scripts/clean-firefox-dist.mjs && wxt build -b firefox",
    "package:amo-source": "node scripts/package-amo-source.mjs",
    "package:chrome": "pnpm run build:chrome && cd dist/chrome-mv3 && zip -r ../chrome.zip .",
    "package:firefox": "pnpm run build:firefox && cd dist/firefox-mv2 && zip -r ../firefox.zip .",
    "icons": "tsx scripts/generate-icons.ts"
  },
  "dependencies": {
    "@mozilla/readability": "latest",
    "marked": "^18.0.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "latest",
    "@types/mozilla-readability": "latest",
    "@sveltejs/vite-plugin-svelte": "4.0.4",
    "svelte": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "5.4.21",
    "wxt": "0.19.29"
  },
  "pnpm": {
    "overrides": {
      "@sveltejs/vite-plugin-svelte": "4.0.4",
      "vite": "5.4.21"
    }
  }
}
