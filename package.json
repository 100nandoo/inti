{
  "name": "inti-web-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build && node scripts/render-unauthorized-page.mjs",
    "dev:web": "vite",
    "watch:web": "node scripts/watch-web.mjs",
    "test:web": "tsx --test web/js/*.test.js web/js/*.test.ts",
    "typecheck:web": "svelte-check --tsconfig ./tsconfig.web.json",
    "typecheck:web:test": "tsc -p ./tsconfig.web-tests.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "jsdom": "^26.1.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "tsx": "^4.20.6",
    "vite": "^6.4.2"
  }
}
