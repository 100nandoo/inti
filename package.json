{
  "name": "inti-web-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web:css": "./node_modules/.bin/tailwindcss -i ./web-src/src/tailwind.css -o ./web/tailwind.css --minify",
    "build:web": "npm run build:web:css && vite build && node scripts/sync-web-public.mjs && node scripts/render-unauthorized-page.mjs",
    "dev:web": "vite",
    "watch:web": "node scripts/watch-web.mjs",
    "test:web": "tsx --test tests/web/*.test.ts",
    "typecheck:web": "svelte-check --tsconfig ./tsconfig.web.json",
    "typecheck:web:test": "tsc -p ./tsconfig.web-tests.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/cli": "^4.3.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "daisyui": "^5.5.19",
    "jsdom": "^26.1.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "^6.4.2"
  }
}
